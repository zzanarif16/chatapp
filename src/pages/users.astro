---
// Ganti URL di bawah dengan URL backend API Anda setelah deploy (misal dari Vercel)
const response = await fetch('https://chatapp-backend.vercel.app/api/users');
const users = await response.json();
---
<html>
  <body>
    <h1>Daftar User</h1>
    <ul>
      {users.map(user => <li>{user.name} ({user.phone})</li>)}
    </ul>
  </body>
</html>
